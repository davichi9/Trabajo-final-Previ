{% extends 'base.html.twig' %}

{% block title %}Pedido #{{ pedido.id }} – Tintorería Previ{% endblock %}

{% block body %}

    <section class="section">
        <div class="container resultado-container">

            <div class="resultado-header">
                <div>
                    <h1>Pedido <span class="resultado-num">#{{ pedido.id }}</span></h1>
                    <p class="resultado-sub">Aquí tienes el estado actual de tu pedido.</p>
                </div>
                {% set estadoLabels = {'no terminado': 'En proceso', 'terminado': 'Listo para recoger', 'recogido': 'Recogido'} %}
                <span class="badge badge--{{ pedido.estado|replace({' ': '-'}) }} badge-lg">
                    {{ estadoLabels[pedido.estado] ?? pedido.estado }}
                </span>
            </div>

            <table class="resultado-tabla">
                <tbody>
                    <tr>
                        <th>Número de pedido</th>
                        <td>#{{ pedido.id }}</td>
                    </tr>
                    <tr>
                        <th>Nombre del cliente</th>
                        <td>{{ pedido.cliente.nombre }} {{ pedido.cliente.apellidos }}</td>
                    </tr>
                    <tr>
                        <th>Teléfono del cliente</th>
                        <td>{{ pedido.cliente.telefonoNumero }}</td>
                    </tr>
                    <tr>
                        <th>Contenido</th>
                        <td>{{ pedido.contenido }}</td>
                    </tr>
                    <tr>
                        <th>Fecha de entrada</th>
                        <td>{{ pedido.fechaEntrada|date('d/m/Y') }}</td>
                    </tr>
                    {% if pedido.fechaSalida %}
                    <tr>
                        <th>Fecha de salida</th>
                        <td>{{ pedido.fechaSalida|date('d/m/Y') }}</td>
                    </tr>
                    {% endif %}
                    <tr>
                        <th>Precio</th>
                        <td><strong>{{ pedido.precio|number_format(2, ',', '.') }} €</strong></td>
                    </tr>
                    <tr>
                        <th>Pagado</th>
                        <td class="{{ pedido.pagado ? 'pagado-si' : 'pagado-no' }}">{{ pedido.pagado ? 'Sí' : 'No' }}</td>
                    </tr>
                    <tr>
                        <th>Gestionado por</th>
                        <td>{{ pedido.trabajador ? pedido.trabajador.nombre ~ ' ' ~ pedido.trabajador.apellidos : 'No asignado' }}</td>
                    </tr>
                </tbody>
            </table>

            <div class="resultado-observaciones">
                <h3>Observaciones</h3>
                <p {% if not pedido.observaciones %}class="sin-observaciones"{% endif %}>
                    {{ pedido.observaciones ?: 'No hay observaciones sobre este pedido.' }}
                </p>
            </div>

            <div class="resultado-footer">
                <a href="{{ path('app_pedido') }}" class="btn-secondary">
                    ← Volver a consultar
                </a>
                <button type="button" class="btn-secondary" onclick="document.getElementById('reporte-form').classList.toggle('reporte-form--visible')">
                    Notificar un error en este pedido
                </button>
            </div>

            <div id="reporte-form" class="reporte-form">
                {% for mensaje in app.flashes('reporte_ok') %}
                    <p class="reporte-ok">{{ mensaje }}</p>
                {% endfor %}
                {% for mensaje in app.flashes('reporte_error') %}
                    <p class="pedido-error">{{ mensaje }}</p>
                {% endfor %}
                <form method="post" action="{{ path('app_pedido_reporte', {id: pedido.id}) }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('reporte') }}">
                    <textarea name="mensaje" rows="4" placeholder="Describe el problema o error..." required></textarea>
                    <button type="submit" class="btn-primary">Enviar reporte</button>
                </form>
            </div>

        </div>
    </section>

{% endblock %}
