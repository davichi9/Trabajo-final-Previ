<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Tintorería Previ{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 640 512%22><path fill=%22%23ff6a00%22 d=%22M211.8 0c-7.8 0-14.5 5.3-16.4 12.9L188 40.4C177.1 40.6 166.4 42.3 156.2 45.7L144 16c-3.1-7.3-10.3-12-18.2-12C78.6 4 32 54.4 32 116c0 19.9 16.1 36 36 36h48v324c0 19.9 16.1 36 36 36h336c19.9 0 36-16.1 36-36V152h48c19.9 0 36-16.1 36-36 0-61.6-46.6-112-113.8-112-7.9 0-15.1 4.7-18.2 12l-12.2 29.7c-10.2-3.4-20.9-5.1-31.8-5.3l-7.4-27.5C428.7 5.3 422 0 414.2 0H211.8z%22/></svg>">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>

        <header class="site-header">
            <div class="header-left">
                <i class="fas fa-shirt header-logo"></i>
                <span class="header-brand">Tintorería Previ</span>
            </div>
            <nav class="header-nav">
                <a href="{{ path('app_home') }}">Inicio</a>
                <a href="{{ path('app_home') }}#precios">Precios</a>
                <a href="{{ path('app_home') }}#ubicacion">Ubicación</a>
                <a href="{{ path('app_home') }}#contacto">Contacto</a>
            </nav>
            <div class="header-right">
                <a href="/login" class="btn-login">Acceso Empleados</a>
            </div>
        </header>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="site-footer" id="contacto">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>📞 Teléfono</h4>
                    <p><a href="tel:+34600000000">+34 600 000 000</a></p>
                </div>
                <div class="footer-col">
                    <h4>✉️ Email</h4>
                    <p><a href="mailto:info@tintoreria-previ.es">info@tintoreria-previ.es</a></p>
                </div>
                <div class="footer-col">
                    <h4>📍 Ubicación</h4>
                    <p>Calle Ejemplo 123, 46001 Valencia</p>
                </div>
                <div class="footer-col">
                    <h4>🕐 Horario</h4>
                    <p>Lun–Vie: 9:00 – 20:00</p>
                    <p>Sábado: 9:00 – 14:00</p>
                    <p>Domingo: Cerrado</p>
                </div>
            </div>
            <p class="footer-copy">&copy; {{ "now"|date("Y") }} Tintorería Previ. Todos los derechos reservados.</p>
        </footer>

    </body>
</html>
