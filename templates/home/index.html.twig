{% extends 'base.html.twig' %}

{% block title %}Inicio – Tintorería Previ{% endblock %}

{% block body %}

    {# HERO #}
    <section class="hero">
        <div class="hero-content">
            <h1>Bienvenido a Tintorería Previ</h1>
            <p>Tu ropa, impecable. Servicio profesional de limpieza y planchado desde 1990.</p>
            <div class="hero-buttons">
                <a href="{{ path('app_pedido') }}" class="btn-primary">Consultar mi pedido</a>
            </div>
        </div>
    </section>

    {# PRECIOS #}
    <section class="section" id="precios">
        <div class="container">
            <h2>Nuestros Precios</h2>
            <div class="precios-img-wrap">
                <img src="{{ asset('images/precios.png') }}" alt="Lista de precios de Tintorería Previ" class="precios-img">
            </div>
        </div>
    </section>

    {# CONSULTAR PEDIDO #}
    <section class="section section-alt">
        <div class="container text-center">
            <h2>¿Está tu ropa lista?</h2>
            <p>Introduce tu número de pedido y teléfono para consultar el estado de tu ropa.</p>
            <a href="{{ path('app_pedido') }}" class="btn-primary">Consultar estado del pedido</a>
        </div>
    </section>

    {# UBICACIÓN #}
    <section class="section" id="ubicacion">
        <div class="container">
            <h2>Ubicación</h2>
            <div class="ubicacion-grid">
                <div>
                    <p>📍 <strong>C/ Algabeño 51, Madrid</strong></p>
                    <p>🕐 Lunes a Viernes: 10:00 – 13:30 / 16:30 – 19:30</p>
                    <p>📞 <a href="tel:+34630233032">630 233 032</a></p>
                    <p>✉️ <a href="mailto:tintoprevi@gmail.com">tintoprevi@gmail.com</a></p>
                </div>
                <div class="map-container">
                    <iframe
                        src="https://maps.google.com/maps?q=Calle+Algabe%C3%B1o+51+Madrid+Spain&output=embed&hl=es"
                        width="100%"
                        height="350"
                        style="border:0; border-radius: 8px;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Ubicación Tintorería Previ - C/ Algabeño 51, Madrid">
                    </iframe>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
