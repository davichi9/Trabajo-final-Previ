{% extends 'base.html.twig' %}

{% block title %}Inicio – Tintorería Previ{% endblock %}

{% block body %}

    {# HERO #}
    <section class="hero">
        <div class="hero-content">
            <h1>Bienvenido a Tintorería Previ</h1>
            <p>Tu ropa, impecable. Servicio profesional de limpieza y planchado desde 1990.</p>
            <div class="hero-buttons">
                <a href="{{ path('app_pedido') }}" class="btn-primary">Consultar mi pedido</a>
                <a href="{{ path('app_login') }}" class="btn-secondary">Acceso Empleados</a>
            </div>
        </div>
    </section>

    {# PRECIOS #}
    <section class="section" id="precios">
        <div class="container">
            <h2>Nuestros Precios</h2>
            <div class="cards">
                <div class="card">
                    <span class="card-icon">👕</span>
                    <h3>Camisas / Camisetas</h3>
                    <p class="price">desde <strong>3,50 €</strong></p>
                    <p>Lavado y planchado incluido</p>
                </div>
                <div class="card">
                    <span class="card-icon">🧥</span>
                    <h3>Trajes / Americana</h3>
                    <p class="price">desde <strong>12,00 €</strong></p>
                    <p>Limpieza en seco profesional</p>
                </div>
                <div class="card">
                    <span class="card-icon">👖</span>
                    <h3>Pantalones</h3>
                    <p class="price">desde <strong>5,00 €</strong></p>
                    <p>Lavado, secado y planchado</p>
                </div>
                <div class="card">
                    <span class="card-icon">🧣</span>
                    <h3>Edredones / Ropa de cama</h3>
                    <p class="price">desde <strong>15,00 €</strong></p>
                    <p>Lavado y tratamiento especial</p>
                </div>
            </div>
        </div>
    </section>

    {# CONSULTAR PEDIDO #}
    <section class="section section-alt">
        <div class="container text-center">
            <h2>¿Está tu ropa lista?</h2>
            <p>Introduce tu número de pedido y teléfono para consultar el estado de tu ropa.</p>
            <a href="{{ path('app_pedido') }}" class="btn-primary">Consultar estado del pedido</a>
        </div>
    </section>

    {# UBICACIÓN #}
    <section class="section" id="ubicacion">
        <div class="container">
            <h2>Ubicación</h2>
            <div class="ubicacion-grid">
                <div>
                    <p>📍 <strong>C/ Algabeño 51</strong></p>
                    <p>🕐 Lunes a Viernes: 10:00 – 13:30 / 16:30 – 19:30</p>
                    <p>📞 <a href="tel:+34630233032">630 233 032</a></p>
                    <p>✉️ <a href="mailto:tintoprevi@gmail.com">tintoprevi@gmail.com</a></p>
                </div>
                <div class="map-placeholder">
                    <p>🗺️ Mapa próximamente</p>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
