{% extends "base.html.twig" %}

{% block title %}Pedidos - Lavandería{% endblock %}

{% block body %}
<div class="dashboard-container">
    <nav class="dashboard-navbar">
        <div class="dashboard-navbar-content">
            <h2>Lavandería - Pedidos</h2>
            <div class="navbar-user">
                <span>Bienvenido, {{ trabajador_name }} <span class="badge">{{ trabajador_role }}</span></span>
                <form method="POST" action="{{ path('app_logout') }}" class="logout-form">
                    <button type="submit" class="btn-logout">Cerrar Sesión</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="dashboard-content">
        <div class="content-header">
            <h1>Lista de pedidos</h1>
            <a href="{{ path('app_dashboard') }}" class="btn-secondary">Volver al Dashboard</a>
        </div>

        <div class="search-box-container">
            <div class="search-filters">
                <a href="{{ path('app_pedidos_list', app.request.query.all|merge({'estado': estadoFiltro == 'recogido' ? null : 'recogido', 'search': searchTerm})|filter(v => v is not null)) }}"
                   class="btn-toggle {{ estadoFiltro == 'recogido' ? 'btn-toggle--active' }}">
                    Recogidos
                </a>
                <a href="{{ path('app_pedidos_list', app.request.query.all|merge({'pagado': pagadoFiltro == '1' ? null : '1', 'search': searchTerm})|filter(v => v is not null)) }}"
                   class="btn-toggle {{ pagadoFiltro == '1' ? 'btn-toggle--active' }}">
                    Pagados
                </a>
            </div>
            <form method="GET" action="{{ path('app_pedidos_list') }}" class="search-form">
                {% if estadoFiltro is not null %}<input type="hidden" name="estado" value="{{ estadoFiltro }}">{% endif %}
                {% if pagadoFiltro is not null %}<input type="hidden" name="pagado" value="{{ pagadoFiltro }}">{% endif %}
                <input
                    type="text"
                    name="search"
                    class="search-input"
                    placeholder="Buscar por número de pedido..."
                    value="{{ searchTerm }}"
                >
                <button type="submit" class="btn-search">Buscar</button>
                {% if searchTerm or estadoFiltro is not null or pagadoFiltro is not null %}
                    <a href="{{ path('app_pedidos_list') }}" class="btn-clear">Limpiar</a>
                {% endif %}
            </form>
        </div>

        {% if pedidos %}
            <div class="clients-table-container">
                <table class="clients-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Estado</th>
                            <th>Fecha entrada</th>
                            <th>Precio</th>
                            <th>Pagado</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pedido in pedidos %}
                            <tr>
                                <td>#{{ pedido.id }}</td>
                                <td>{{ pedido.cliente.nombre }} {{ pedido.cliente.apellidos }}</td>
                                <td>{{ pedido.estado }}</td>
                                <td>{{ pedido.fechaEntrada|date('d/m/Y') }}</td>
                                <td>{{ pedido.precio|number_format(2, ',', '.') }} €</td>
                                <td>{{ pedido.pagado ? 'Sí' : 'No' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="empty-state">
                <p>No hay pedidos registrados.</p>
            </div>
        {% endif %}
    </div>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .search-box-container {
        margin-bottom: 2rem;
    }

    .search-filters {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .btn-toggle {
        padding: 0.5rem 1rem;
        background-color: #e9ecef;
        color: #333;
        text-decoration: none;
        border-radius: 4px;
        font-size: 0.9rem;
        transition: background-color 0.2s;
    }

    .btn-toggle:hover { background-color: #dee2e6; }

    .btn-toggle--active {
        background-color: #ff6a00;
        color: white;
    }

    .btn-toggle--active:hover { background-color: #e55a00; }

    .search-form {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .search-input {
        flex: 1;
        min-width: 250px;
        padding: 0.75rem 1rem;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        font-size: 0.95rem;
        transition: border-color 0.3s;
    }

    .search-input:focus {
        outline: none;
        border-color: #007bff;
        box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
    }

    .btn-search {
        padding: 0.75rem 1.5rem;
        background-color: #ff6a00;
        color: white;
        border: none;
        border-radius: 4px;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background-color 0.3s;
    }

    .btn-search:hover {
        background-color: #e55a00;
    }

    .btn-clear {
        padding: 0.75rem 1.5rem;
        background-color: #6c757d;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        font-size: 0.95rem;
        transition: background-color 0.3s;
        display: inline-block;
    }

    .btn-clear:hover {
        background-color: #5a6268;
    }

    .btn-secondary {
        padding: 0.5rem 1rem;
        background-color: #6c757d;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        font-size: 0.95rem;
        transition: background-color 0.3s;
    }

    .btn-secondary:hover {
        background-color: #5a6268;
    }

    .clients-table-container {
        overflow-x: auto;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .clients-table {
        width: 100%;
        border-collapse: collapse;
        background-color: white;
    }

    .clients-table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .clients-table th {
        padding: 1rem;
        text-align: left;
        font-weight: 600;
        color: #333;
    }

    .clients-table td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #dee2e6;
    }

    .clients-table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .clients-table tbody tr:last-child td {
        border-bottom: none;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        background-color: #f8f9fa;
        border-radius: 8px;
        color: #6c757d;
    }
</style>
{% endblock %}

{% block footer %}{% endblock %}
