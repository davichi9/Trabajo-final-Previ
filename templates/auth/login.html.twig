{% extends "base.html.twig" %}

{% block title %}Acceso Empleados - Lavandería{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-card">
        <h1>Acceso Empleados</h1>
        
        {% if error %}
            <div class="alert-error">
                {{ error }}
            </div>
        {% endif %}

        <form method="POST" action="{{ path('app_login') }}" class="login-form">
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input 
                    type="email" 
                    class="form-input" 
                    id="email" 
                    name="email" 
                    placeholder="correo@empresa.com"
                    required
                >
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Contraseña</label>
                <input 
                    type="password" 
                    class="form-input" 
                    id="password" 
                    name="password" 
                    placeholder="Introduce tu contraseña"
                    required
                >
            </div>

            <button type="submit" class="btn-primary btn-block">Iniciar Sesión</button>
        </form>

        <div class="login-footer">
            <a href="{{ path('app_home') }}" class="login-link">Volver al inicio</a>
        </div>
    </div>
</div>
{% endblock %}
